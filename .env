# ตั้งค่า port ของเซิร์ฟเวอร์
PORT=3000

# ข้อมูลการเชื่อมต่อฐานข้อมูล MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mfu_election
DB_USER=root
DB_PASS=bb12345677

# Secret key สำหรับ session (เปลี่ยนให้ยาวและซับซ้อนใน production)
SESSION_SECRET=mfu_election_super_secret_key_change_in_production

# ข้อมูล login ของ Admin (เก็บใน env ไม่ใช่ DB)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
