<%- include('../partials/header', { title: 'ประวัติการโหวต' }) %>

<div class="page-header mb-6">
  <h1 class="text-2xl font-bold text-gray-800">ประวัติการโหวต</h1>
  <p class="text-gray-500 text-sm mt-1">บัตรประชาชน: <%= session.citizen_id %></p>
</div>

<% if (vote) { %>
  <!-- กรณีที่โหวตแล้ว: แสดงรายละเอียด -->
  <div class="mfu-card max-w-lg mx-auto text-center">
    <div class="text-5xl mb-4">✅</div>
    <h2 class="text-xl font-bold text-gray-800 mb-1">คุณได้ลงคะแนนแล้ว</h2>
    <p class="text-gray-500 text-sm mb-6">
      เมื่อ <%= new Date(vote.voted_at).toLocaleString('th-TH') %>
    </p>

    <!-- ข้อมูลผู้สมัครที่เลือก -->
    <div class="bg-gray-50 rounded-xl p-5 text-left">
      <div class="flex items-center gap-4 mb-4">
        <div class="avatar-lg text-xl"><%= vote.number %></div>
        <div>
          <div class="font-bold text-lg text-gray-800"><%= vote.full_name %></div>
          <div class="text-sm text-gray-500">
            หมายเลข <%= vote.number %> &nbsp;|&nbsp; <%= vote.candidate_id %>
          </div>
        </div>
      </div>
      <!-- นโยบายของผู้สมัครที่เลือก -->
      <% if (vote.policy) { %>
        <div class="border-t border-gray-200 pt-4">
          <p class="text-xs font-medium text-gray-500 mb-2 uppercase tracking-wide">นโยบาย</p>
          <p class="text-gray-600 text-sm leading-relaxed"><%= vote.policy %></p>
        </div>
      <% } %>
    </div>

    <a href="/voter/results" class="btn-primary inline-block mt-5">ดูผลคะแนนทั้งหมด</a>
  </div>

<% } else { %>
  <!-- กรณีที่ยังไม่ได้โหวต -->
  <div class="mfu-card max-w-lg mx-auto text-center py-12">
    <div class="text-5xl mb-4">📋</div>
    <h2 class="text-xl font-bold text-gray-700 mb-2">ยังไม่มีประวัติการโหวต</h2>
    <p class="text-gray-400 text-sm mb-6">คุณยังไม่ได้ลงคะแนนเสียง</p>
    <a href="/voter/dashboard" class="btn-primary">ไปลงคะแนนเสียง</a>
  </div>
<% } %>

<%- include('../partials/footer') %>
