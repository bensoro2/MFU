<%- include('../partials/header', { title: 'Dashboard ผู้สมัคร' }) %>

<!-- Page Header พร้อม avatar ชื่อผู้สมัคร -->
<div class="page-header mb-6 flex items-center gap-4">
  <div class="avatar-lg"><%= candidate.number %></div>
  <div>
    <h1 class="text-2xl font-bold text-gray-800"><%= candidate.full_name || session.candidate_code %></h1>
    <p class="text-gray-500 text-sm"><%= candidate.candidate_id %> &nbsp;|&nbsp; ผู้สมัครหมายเลข <%= candidate.number %></p>
  </div>
</div>

<!-- Stat Cards: ผลของตัวเอง -->
<div class="grid grid-cols-3 gap-4 mb-6">
  <div class="stat-card border-l-4 border-mfu-maroon">
    <div class="stat-label">คะแนนของฉัน</div>
    <div class="stat-value text-mfu-maroon"><%= myVotes %></div>
  </div>
  <div class="stat-card border-l-4 border-mfu-gold">
    <div class="stat-label">อันดับของฉัน</div>
    <div class="stat-value text-yellow-600">#<%= myRank %></div>
  </div>
  <div class="stat-card border-l-4 border-blue-400">
    <div class="stat-label">% คะแนนของฉัน</div>
    <div class="stat-value text-blue-600"><%= myPct %>%</div>
  </div>
</div>

<!-- สถิติรวมระบบ -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
  <div class="stat-card">
    <div class="stat-label">ผู้มีสิทธิ์โหวต</div>
    <div class="stat-value"><%= totalVoters %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">ผู้สมัครทั้งหมด</div>
    <div class="stat-value"><%= totalCandidates %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">โหวตแล้ว</div>
    <div class="stat-value"><%= totalVotes %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">% มาใช้สิทธิ์</div>
    <div class="stat-value"><%= overallPct %>%</div>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">

  <!-- นโยบายของผู้สมัคร -->
  <div class="mfu-card">
    <div class="flex items-center justify-between mb-3">
      <h2 class="section-title">นโยบายของฉัน</h2>
      <a href="/candidate/profile" class="text-xs text-mfu-maroon hover:underline">แก้ไข →</a>
    </div>
    <% if (candidate.policy) { %>
      <p class="text-gray-600 text-sm leading-relaxed"><%= candidate.policy %></p>
    <% } else { %>
      <p class="text-gray-400 text-sm italic">
        ยังไม่ได้กรอกนโยบาย &nbsp;
        <a href="/candidate/profile" class="text-mfu-maroon hover:underline">คลิกเพื่อเพิ่ม</a>
      </p>
    <% } %>
  </div>

  <!-- อันดับ Top 5 (highlight ตัวเอง) -->
  <div class="mfu-card">
    <div class="flex items-center justify-between mb-3">
      <h2 class="section-title">อันดับคะแนน (Top 5)</h2>
      <a href="/candidate/results" class="text-xs text-mfu-maroon hover:underline">ดูทั้งหมด →</a>
    </div>
    <% if (top5.length === 0) { %>
      <p class="text-gray-400 text-sm text-center py-4">ยังไม่มีคะแนน</p>
    <% } else { %>
      <% top5.forEach((c, i) => {
           const isMe = c.id === candidate.id;
           const pct  = totalVotes > 0 ? ((c.vote_count / totalVotes) * 100).toFixed(1) : '0.0';
      %>
        <!-- highlight แถวที่เป็นตัวเอง -->
        <div class="mb-3 <%= isMe ? 'bg-yellow-50 rounded-lg p-2 -mx-2' : '' %>">
          <div class="flex items-center justify-between mb-1">
            <div class="flex items-center gap-2">
              <% if (i === 0) { %>
                <span class="badge-gold">1</span>
              <% } else { %>
                <span class="text-gray-400 text-xs w-5 text-center"><%= i+1 %></span>
              <% } %>
              <span class="text-sm font-medium <%= isMe ? 'text-mfu-maroon font-bold' : 'text-gray-700' %>">
                <%= c.full_name || c.candidate_id %>
                <% if (isMe) { %> <span class="text-xs text-yellow-600">(ฉัน)</span><% } %>
              </span>
            </div>
            <span class="text-xs text-gray-500"><%= c.vote_count %> (<%= pct %>%)</span>
          </div>
          <div class="vote-bar">
            <div class="vote-fill <%= isMe ? 'bg-mfu-gold' : '' %>" style="width: <%= pct %>%"></div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

</div>

<%- include('../partials/footer') %>
