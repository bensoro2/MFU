<%- include('../partials/header', { title: 'จัดการผู้ลงคะแนน' }) %>

<div class="page-header mb-6">
  <h1 class="text-2xl font-bold text-gray-800">จัดการผู้มีสิทธิ์ลงคะแนน</h1>
  <p class="text-gray-500 text-sm mt-1">เพิ่ม แก้ไข ลบ และเปิด/ปิดบัญชีผู้มีสิทธิ์โหวต</p>
</div>

<!-- สถิติสรุปด้านบน -->
<div class="grid grid-cols-3 gap-4 mb-6">
  <div class="stat-card">
    <div class="stat-label">ทั้งหมด</div>
    <div class="stat-value"><%= total %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">เปิดใช้งาน</div>
    <div class="stat-value text-green-600"><%= active %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">โหวตแล้ว</div>
    <div class="stat-value text-mfu-maroon"><%= voted %></div>
  </div>
</div>

<!-- ฟอร์มเพิ่มผู้มีสิทธิ์โหวต -->
<div class="mfu-card mb-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="section-title">เพิ่มผู้มีสิทธิ์โหวต</h2>
    <button onclick="toggleAddForm()" class="btn-gold text-sm">+ เพิ่ม</button>
  </div>
  <div id="add-form" class="hidden">
    <form method="POST" action="/admin/add-voter" class="flex flex-wrap gap-3 items-end">
      <input type="hidden" name="csrf_token" value="<%= csrf_token %>" />
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-gray-600 mb-1">เลขบัตรประชาชน (13 หลัก)</label>
        <input type="text" name="citizen_id" maxlength="13" placeholder="1234567890123"
               class="input-field" required />
      </div>
      <div class="flex-1 min-w-[180px]">
        <label class="block text-xs font-medium text-gray-600 mb-1">รหัสหลังบัตร (Laser ID)</label>
        <input type="text" name="laser_id" placeholder="AA0-0000001-00"
               oninput="this.value = this.value.toUpperCase()"
               class="input-field" required />
      </div>
      <div class="flex gap-2">
        <button type="submit" class="btn-primary text-sm">เพิ่ม</button>
        <button type="button" onclick="toggleAddForm()" class="btn-outline text-sm">ยกเลิก</button>
      </div>
    </form>
  </div>
</div>

<!-- ช่องค้นหา -->
<form method="GET" action="/admin/voters" class="mb-4">
  <div class="search-bar">
    <input type="text" name="search" placeholder="ค้นหาเลขบัตรประชาชนหรือรหัสหลังบัตร..."
           value="<%= search %>" class="flex-1 bg-transparent outline-none text-sm" />
    <button type="submit" class="text-gray-400 hover:text-gray-600 text-sm">ค้นหา</button>
    <% if (search) { %>
      <a href="/admin/voters" class="text-xs text-gray-400 hover:text-red-500">✕ ล้าง</a>
    <% } %>
  </div>
</form>

<!-- ตารางรายชื่อผู้มีสิทธิ์โหวต -->
<div class="mfu-card overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-100 text-left text-gray-500 text-xs uppercase tracking-wide">
        <th class="pb-3 pr-4">เลขบัตรประชาชน</th>
        <th class="pb-3 pr-4">รหัสหลังบัตร</th>
        <th class="pb-3 pr-4 text-center">สถานะ</th>
        <th class="pb-3 pr-4 text-center">โหวต</th>
        <th class="pb-3 text-center">จัดการ</th>
      </tr>
    </thead>
    <tbody>
      <% if (voters.length === 0) { %>
        <tr><td colspan="5" class="py-8 text-center text-gray-400">ไม่พบข้อมูล</td></tr>
      <% } else { %>
        <% voters.forEach(v => { %>
          <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
            <td class="py-3 pr-4 font-mono text-gray-700"><%= v.citizen_id %></td>
            <td class="py-3 pr-4 font-mono text-gray-500"><%= v.laser_id %></td>
            <td class="py-3 pr-4 text-center">
              <% if (v.is_enabled) { %>
                <span class="badge-ok">เปิดใช้งาน</span>
              <% } else { %>
                <span class="badge-dis">ปิดการใช้งาน</span>
              <% } %>
            </td>
            <td class="py-3 pr-4 text-center">
              <% if (v.has_voted) { %>
                <span class="badge-gold">โหวตแล้ว</span>
              <% } else { %>
                <span class="text-gray-400 text-xs">ยังไม่โหวต</span>
              <% } %>
            </td>
            <td class="py-3 text-center">
              <div class="flex items-center justify-center gap-1">
                <!-- ปุ่ม Enable/Disable -->
                <form method="POST" action="/admin/toggle-voter" class="inline">
                  <input type="hidden" name="csrf_token" value="<%= csrf_token %>" />
                  <input type="hidden" name="id" value="<%= v.id %>" />
                  <% if (v.is_enabled) { %>
                    <input type="hidden" name="action" value="disable" />
                    <button type="submit" class="btn-sm-danger"
                            onclick="return confirm('ปิดบัญชีนี้?')">ปิด</button>
                  <% } else { %>
                    <input type="hidden" name="action" value="enable" />
                    <button type="submit" class="btn-sm-success">เปิด</button>
                  <% } %>
                </form>

                <!-- ปุ่มแก้ไข (ไม่แสดงถ้าโหวตแล้ว) -->
                <% if (!v.has_voted) { %>
                  <button onclick="openEditVoter(<%= v.id %>, '<%= v.citizen_id %>', '<%= v.laser_id %>')"
                          class="btn-sm-edit">แก้ไข</button>
                <% } %>

                <!-- ปุ่มลบ (ไม่แสดงถ้าโหวตแล้ว) -->
                <% if (!v.has_voted) { %>
                  <form method="POST" action="/admin/delete-voter" class="inline">
                    <input type="hidden" name="csrf_token" value="<%= csrf_token %>" />
                    <input type="hidden" name="id" value="<%= v.id %>" />
                    <button type="submit" class="btn-sm-del"
                            onclick="return confirm('ลบผู้มีสิทธิ์โหวตรายนี้?')">ลบ</button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div class="mt-4 flex justify-center gap-2">
      <% for (let p = 1; p <= totalPages; p++) { %>
        <a href="/admin/voters?page=<%= p %><%= search ? '&search=' + search : '' %>"
           class="pagination <%= p === page ? 'active' : '' %>">
          <%= p %>
        </a>
      <% } %>
    </div>
  <% } %>
</div>

<!-- Modal แก้ไขผู้มีสิทธิ์โหวต -->
<div id="modal-edit-voter" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4 p-6">
    <h3 class="text-lg font-bold text-gray-800 mb-4">แก้ไขข้อมูลผู้มีสิทธิ์โหวต</h3>
    <form method="POST" action="/admin/edit-voter">
      <input type="hidden" name="csrf_token" value="<%= csrf_token %>" />
      <input type="hidden" name="id" id="edit-voter-id" />
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">เลขบัตรประชาชน</label>
        <input type="text" name="citizen_id" id="edit-voter-citizen"
               maxlength="13" class="input-field" placeholder="1234567890123" required />
        <p class="text-xs text-gray-400 mt-1">ตัวเลข 13 หลัก</p>
      </div>
      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-1">รหัสหลังบัตร (Laser ID)</label>
        <input type="text" name="laser_id" id="edit-voter-laser"
               oninput="this.value = this.value.toUpperCase()"
               class="input-field" placeholder="AA0-0000001-00" required />
      </div>
      <div class="flex gap-3 justify-end">
        <button type="button" onclick="closeEditVoter()" class="btn-outline">ยกเลิก</button>
        <button type="submit" class="btn-primary">บันทึก</button>
      </div>
    </form>
  </div>
</div>

<script>
  function toggleAddForm() {
    document.getElementById('add-form').classList.toggle('hidden');
  }

  function openEditVoter(id, citizenId, laserId) {
    document.getElementById('edit-voter-id').value      = id;
    document.getElementById('edit-voter-citizen').value = citizenId;
    document.getElementById('edit-voter-laser').value   = laserId;
    const modal = document.getElementById('modal-edit-voter');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeEditVoter() {
    const modal = document.getElementById('modal-edit-voter');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  // ปิด modal เมื่อคลิก backdrop
  document.getElementById('modal-edit-voter').addEventListener('click', function(e) {
    if (e.target === this) closeEditVoter();
  });
</script>

<%- include('../partials/footer') %>
