<%- include('../partials/header', { title: 'Admin Dashboard' }) %>

<!-- Page Header -->
<div class="page-header mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Admin Dashboard</h1>
  <p class="text-gray-500 text-sm mt-1">ภาพรวมระบบเลือกตั้ง</p>
</div>

<!-- Stat Cards: แสดง 4 ตัวเลขสำคัญ -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="stat-card">
    <div class="stat-label">ผู้มีสิทธิ์โหวต</div>
    <div class="stat-value"><%= stats.totalVoters %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">ผู้สมัคร</div>
    <div class="stat-value"><%= stats.totalCandidates %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">โหวตแล้ว</div>
    <div class="stat-value"><%= stats.totalVotes %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">% ผู้มาใช้สิทธิ์</div>
    <div class="stat-value text-mfu-maroon"><%= stats.pct %>%</div>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

  <!-- การตั้งค่าระบบ -->
  <div class="mfu-card">
    <h2 class="section-title mb-4">การตั้งค่าระบบ</h2>

    <!-- Toggle: เปิด/ปิดการโหวต -->
    <form method="POST" action="/admin/toggle-settings" class="data-row">
      <input type="hidden" name="csrf_token" value="<%= csrf_token %>" />
      <input type="hidden" name="setting"    value="voting_enabled" />
      <div>
        <div class="font-medium text-gray-700">เปิดรับโหวต</div>
        <div class="text-xs text-gray-400 mt-0.5">อนุญาตให้ผู้มีสิทธิ์ลงคะแนนได้</div>
      </div>
      <!-- auto-submit เมื่อ toggle เปลี่ยน -->
      <label class="toggle-switch">
        <input type="checkbox" name="value" value="1"
               onchange="this.form.submit()"
               <%= votingEnabled === '1' ? 'checked' : '' %> />
        <span class="toggle-slider"></span>
      </label>
    </form>

    <!-- Toggle: เปิด/ปิดการลงทะเบียนผู้สมัคร -->
    <form method="POST" action="/admin/toggle-settings" class="data-row mt-3">
      <input type="hidden" name="csrf_token" value="<%= csrf_token %>" />
      <input type="hidden" name="setting"    value="registration_enabled" />
      <div>
        <div class="font-medium text-gray-700">เปิดรับลงทะเบียนผู้สมัคร</div>
        <div class="text-xs text-gray-400 mt-0.5">อนุญาตให้ผู้สมัครลงทะเบียนได้</div>
      </div>
      <label class="toggle-switch">
        <input type="checkbox" name="value" value="1"
               onchange="this.form.submit()"
               <%= registrationEnabled === '1' ? 'checked' : '' %> />
        <span class="toggle-slider"></span>
      </label>
    </form>

    <!-- Quick links -->
    <div class="mt-5 flex gap-3">
      <a href="/admin/candidates" class="btn-outline text-sm flex-1 text-center py-2">จัดการผู้สมัคร</a>
      <a href="/admin/voters"     class="btn-outline text-sm flex-1 text-center py-2">จัดการผู้ลงคะแนน</a>
    </div>
  </div>

  <!-- Preview ผลคะแนนสูงสุด top 5 -->
  <div class="mfu-card">
    <div class="flex items-center justify-between mb-4">
      <h2 class="section-title">ผลคะแนน (Top 5)</h2>
      <a href="/admin/results" class="text-xs text-mfu-maroon hover:underline">ดูทั้งหมด →</a>
    </div>

    <% if (topCandidates.length === 0) { %>
      <p class="text-gray-400 text-sm text-center py-4">ยังไม่มีข้อมูลผู้สมัคร</p>
    <% } else { %>
      <% topCandidates.forEach((c, i) => {
           const pct = stats.totalVotes > 0 ? Math.round((c.vote_count / stats.totalVotes) * 100) : 0;
      %>
        <div class="mb-3">
          <div class="flex items-center justify-between mb-1">
            <div class="flex items-center gap-2">
              <!-- Badge อันดับ 1-3 ใช้สีทอง/เงิน/ทองแดง -->
              <% if (i === 0) { %>
                <span class="badge-gold">1</span>
              <% } else { %>
                <span class="text-gray-400 text-xs w-5 text-center"><%= i+1 %></span>
              <% } %>
              <span class="text-sm font-medium text-gray-700 truncate max-w-[160px]">
                <%= c.full_name || `ผู้สมัคร ${c.candidate_id}` %>
              </span>
              <% if (!c.is_enabled) { %><span class="badge-dis text-xs">ปิด</span><% } %>
            </div>
            <span class="text-xs text-gray-500"><%= c.vote_count %> คะแนน (<%= pct %>%)</span>
          </div>
          <!-- แถบแสดง % คะแนน -->
          <div class="vote-bar">
            <div class="vote-fill" style="width: <%= pct %>%"></div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

</div>

<%- include('../partials/footer') %>
