<%- include('../partials/header', { title: 'จัดการผู้สมัคร' }) %>

<div class="page-header mb-6">
  <h1 class="text-2xl font-bold text-gray-800">จัดการผู้สมัคร</h1>
  <p class="text-gray-500 text-sm mt-1">เพิ่ม แก้ไข ลบ และเปิด/ปิดบัญชีผู้สมัคร</p>
</div>

<!-- ฟอร์มเพิ่มผู้สมัครใหม่ -->
<div class="mfu-card mb-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="section-title">เพิ่มผู้สมัครใหม่</h2>
    <button onclick="toggleAddForm()" id="btn-toggle-add" class="btn-gold text-sm">+ เพิ่มผู้สมัคร</button>
  </div>
  <div id="add-form" class="hidden">
    <form method="POST" action="/admin/add-candidate" class="flex flex-wrap gap-3 items-end">
      <input type="hidden" name="csrf_token" value="<%= csrf_token %>" />
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-gray-600 mb-1">Candidate ID (C-XXXX)</label>
        <input type="text" name="candidate_id" placeholder="C-0006" maxlength="6"
               oninput="this.value = this.value.toUpperCase()"
               class="input-field" required />
        <p class="text-xs text-gray-400 mt-1">หมายเลขผู้สมัครจะถูกกำหนดให้อัตโนมัติ</p>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="btn-primary text-sm">เพิ่ม</button>
        <button type="button" onclick="toggleAddForm()" class="btn-outline text-sm">ยกเลิก</button>
      </div>
    </form>
  </div>
</div>

<!-- ช่องค้นหา -->
<form method="GET" action="/admin/candidates" class="mb-4">
  <div class="search-bar">
    <input type="text" name="search" placeholder="ค้นหาชื่อหรือ Candidate ID..."
           value="<%= search %>" class="flex-1 bg-transparent outline-none text-sm" />
    <button type="submit" class="text-gray-400 hover:text-gray-600 text-sm">ค้นหา</button>
    <% if (search) { %>
      <a href="/admin/candidates" class="text-xs text-gray-400 hover:text-red-500">✕ ล้าง</a>
    <% } %>
  </div>
</form>

<!-- ตารางรายชื่อผู้สมัคร -->
<div class="mfu-card overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-100 text-left text-gray-500 text-xs uppercase tracking-wide">
        <th class="pb-3 pr-4">หมายเลข</th>
        <th class="pb-3 pr-4">Candidate ID</th>
        <th class="pb-3 pr-4">ชื่อ-นามสกุล</th>
        <th class="pb-3 pr-4">Email</th>
        <th class="pb-3 pr-4">นโยบาย</th>
        <th class="pb-3 pr-4 text-center">สถานะ</th>
        <th class="pb-3 text-center">จัดการ</th>
      </tr>
    </thead>
    <tbody>
      <% if (candidates.length === 0) { %>
        <tr><td colspan="7" class="py-8 text-center text-gray-400">ไม่พบข้อมูล</td></tr>
      <% } else { %>
        <% candidates.forEach(c => { %>
          <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
            <td class="py-3 pr-4">
              <div class="avatar"><%= c.number || '—' %></div>
            </td>
            <td class="py-3 pr-4 font-mono text-gray-600"><%= c.candidate_id %></td>
            <td class="py-3 pr-4">
              <% if (c.full_name) { %>
                <span class="font-medium text-gray-800"><%= c.full_name %></span>
              <% } else { %>
                <span class="text-gray-400 italic text-xs">ยังไม่ลงทะเบียน</span>
              <% } %>
            </td>
            <td class="py-3 pr-4 text-gray-500"><%= c.email || '—' %></td>
            <td class="py-3 pr-4 text-gray-500 text-sm max-w-[200px]">
              <% if (c.policy) { %>
                <span class="line-clamp-2"><%= c.policy %></span>
              <% } else { %>
                <span class="text-gray-300 italic text-xs">—</span>
              <% } %>
            </td>
            <td class="py-3 pr-4 text-center">
              <% if (!c.is_registered) { %>
                <span class="badge-warn">รอลงทะเบียน</span>
              <% } else if (c.is_enabled) { %>
                <span class="badge-ok">เปิดใช้งาน</span>
              <% } else { %>
                <span class="badge-dis">ปิดการใช้งาน</span>
              <% } %>
            </td>
            <td class="py-3 text-center">
              <div class="flex items-center justify-center gap-1">
                <!-- ปุ่ม Enable/Disable -->
                <form method="POST" action="/admin/toggle-candidate" class="inline">
                  <input type="hidden" name="csrf_token" value="<%= csrf_token %>" />
                  <input type="hidden" name="id" value="<%= c.id %>" />
                  <% if (c.is_enabled) { %>
                    <input type="hidden" name="action" value="disable" />
                    <button type="submit" class="btn-sm-danger"
                            onclick="return confirm('ปิดการใช้งาน <%= c.candidate_id %>?')">ปิด</button>
                  <% } else { %>
                    <input type="hidden" name="action" value="enable" />
                    <button type="submit" class="btn-sm-success">เปิด</button>
                  <% } %>
                </form>

                <!-- ปุ่มแก้ไข -->
                <button onclick="openEditCandidate(<%= c.id %>, '<%= c.candidate_id %>', <%= c.number %>)"
                        class="btn-sm-edit">แก้ไข</button>

                <!-- ปุ่มลบ -->
                <form method="POST" action="/admin/delete-candidate" class="inline">
                  <input type="hidden" name="csrf_token" value="<%= csrf_token %>" />
                  <input type="hidden" name="id" value="<%= c.id %>" />
                  <button type="submit" class="btn-sm-del"
                          onclick="return confirm('ลบผู้สมัคร <%= c.candidate_id %>?\n(ลบไม่ได้ถ้ามีการโหวตแล้ว)')">ลบ</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

<!-- Modal แก้ไขผู้สมัคร -->
<div id="modal-edit-candidate" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4 p-6">
    <h3 class="text-lg font-bold text-gray-800 mb-4">แก้ไขข้อมูลผู้สมัคร</h3>
    <form method="POST" action="/admin/edit-candidate">
      <input type="hidden" name="csrf_token" value="<%= csrf_token %>" />
      <input type="hidden" name="id" id="edit-candidate-id" />
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Candidate ID</label>
        <input type="text" name="candidate_id" id="edit-candidate-code"
               maxlength="6" oninput="this.value = this.value.toUpperCase()"
               class="input-field" placeholder="C-0001" required />
        <p class="text-xs text-gray-400 mt-1">รูปแบบ C-XXXX</p>
      </div>
      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-1">หมายเลขผู้สมัคร</label>
        <p id="edit-candidate-number-display" class="input-field bg-gray-50 text-gray-500 cursor-not-allowed font-mono text-center"></p>
        <p class="text-xs text-gray-400 mt-1">หมายเลขถูกกำหนดโดยระบบอัตโนมัติ</p>
      </div>
      <div class="flex gap-3 justify-end">
        <button type="button" onclick="closeEditCandidate()" class="btn-outline">ยกเลิก</button>
        <button type="submit" class="btn-primary">บันทึก</button>
      </div>
    </form>
  </div>
</div>

<script>
  function toggleAddForm() {
    document.getElementById('add-form').classList.toggle('hidden');
  }

  function openEditCandidate(id, code, number) {
    document.getElementById('edit-candidate-id').value                  = id;
    document.getElementById('edit-candidate-code').value                = code;
    document.getElementById('edit-candidate-number-display').textContent = number;
    const modal = document.getElementById('modal-edit-candidate');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeEditCandidate() {
    const modal = document.getElementById('modal-edit-candidate');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  document.getElementById('modal-edit-candidate').addEventListener('click', function(e) {
    if (e.target === this) closeEditCandidate();
  });
</script>

<%- include('../partials/footer') %>
